{
  "name": "2026_study_lecture",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "build:zip:backend": "npm run build:zip --prefix backend",
    "build:zip:frontend": "node deploy/zip.mjs frontend",
    "build:zip": "node deploy/zip.mjs all",
    "start:prod": "npm run start:prod --prefix backend",
    "preview": "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
