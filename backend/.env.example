# 서버
HOST=0.0.0.0
PORT=3000

# CORS 허용 Origin (쉼표 구분)
# 로컬 + EC2 공인 IP/도메인을 추가하세요.
# 예: http://localhost:5173,http://13.125.x.x:5173,http://my-domain.com
CORS_ORIGINS=http://localhost:5173

# MySQL 8.0 (로컬 설치 기준, 포트 3306)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=lecture_eval

# JWT
JWT_SECRET=change-this-secret-key-in-production
JWT_EXPIRES_IN=1d

# 최초 관리자 계정 (앱 시작 시 자동 생성, 이미 있으면 건너뜀)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234
ADMIN_NAME=관리자
